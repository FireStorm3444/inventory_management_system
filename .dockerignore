# Git and version control
.git
.gitignore

# Python caches and compiled files (recursive matching)
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.so

# Python virtual environments (local development)
.venv/
venv/
env/
ENV/

# Python distribution and packaging artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
.egg
MANIFEST

# Environment variables and local secrets
.env
*.env
.secrets
secrets.*

# IDEs, text editors, and OS metadata
.vscode/
.zed
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db
.ruff_cache/

# Testing and coverage tools
.pytest_cache/
.tox/
.coverage
htmlcov/

# Docker files
docker-compose.yml
docker-compose.override.yml
.dockerignore
